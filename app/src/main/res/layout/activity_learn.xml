<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F9F8"
    tools:context=".wellness.LearmActivity">

    <!-- Header (No Back Button) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        android:background="#009688">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mental Wellness Guide"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Intro Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Empower yourself with knowledge. Understanding your mental health is the first step toward lasting wellness."
                android:textColor="#004D40"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Card 1: Anxiety -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧠 Anxiety &amp; The Brain"
                        android:textColor="#00796B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anxiety is your body's survival mechanism (Fight or Flight). It's not a flaw, it's an alarm system that needs recalibration."
                        android:textColor="#455A64"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/ll_pro_tip_anxiety"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingTop="12dp">
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="💡 PRO-TIP: Name your anxiety. Call it 'The Worry Bird' or 'Arthur'. Thinking of it as a separate external voice makes it 10x easier to ignore."
                            android:textColor="#004D40"
                            android:textStyle="italic" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_btn_anxiety"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See Pro-Tip"
                        android:textColor="#009688"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Sleep -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 Master Your Sleep"
                        android:textColor="#00796B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quality sleep isn't just about hours; it's about REM cycles. Your brain does its 'garbage disposal' work during deep sleep."
                        android:textColor="#455A64"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/ll_pro_tip_sleep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingTop="12dp">
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="💡 PRO-TIP: The 10-3-2-1 Rule. No caffeine 10h before bed, no food 3h, no work 2h, and no screens 1h before sleep."
                            android:textColor="#004D40"
                            android:textStyle="italic" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_btn_sleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See Pro-Tip"
                        android:textColor="#009688"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Reframing -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄 Cognitive Reframing"
                        android:textColor="#00796B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your brain believes what you tell it. Changing your internal dialogue can literally rewire your neural pathways."
                        android:textColor="#455A64"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/ll_pro_tip_reframe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingTop="12dp">
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="💡 PRO-TIP: Catch 'Thinking Traps'. Are you catastrophizing (assuming the worst)? Challenge the thought with evidence: 'Is this 100% true?'"
                            android:textColor="#004D40"
                            android:textStyle="italic" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_btn_reframe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See Pro-Tip"
                        android:textColor="#009688"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 4: Seeking Help -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E0F2F1"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤝 It's Okay to Need Help"
                        android:textColor="#00695C"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="If your feelings keep you from daily activities for more than 2 weeks, it's time to talk. Reaching out is a sign of immense strength."
                        android:textColor="#455A64"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_emergency_link"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show Crisis Support"
                        android:textColor="#00796B"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
