<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    tools:context=".ui.selfhelp.BreathingActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        android:background="@color/md_theme_light_primary"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deep Breathing"
            android:textColor="@color/md_theme_light_onPrimary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_instructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="20dp"
        android:text="Box Breathing (4-4-4-4) is a powerful technique to clear your mind, relax your body, and improve focus."
        android:textColor="@color/md_theme_light_onBackground"
        android:textSize="16sp"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar" />

    <!-- The Breathing Sphere centered on screen -->
    <View
        android:id="@+id/view_breathing_sphere"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/shape_breathing_circle"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Text inside the sphere -->
    <TextView
        android:id="@+id/tv_breathing_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/md_theme_light_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:shadowColor="#44000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3"
        app:layout_constraintTop_toTopOf="@id/view_breathing_sphere"
        app:layout_constraintBottom_toBottomOf="@id/view_breathing_sphere"
        app:layout_constraintStart_toStartOf="@id/view_breathing_sphere"
        app:layout_constraintEnd_toEndOf="@id/view_breathing_sphere" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle_breathing"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="48dp"
        android:text="Begin Exercise"
        android:textSize="18sp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>